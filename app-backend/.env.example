# Core runtime
PORT=8080
DATABASE_URL=postgres://quanta:quanta@postgres:5432/quanta?sslmode=disable
REDIS_URL=redis://redis:6379/0

# Object storage (AWS S3)
OBJECT_STORAGE_MODE=local
OBJECT_STORAGE_LOCAL_DIR=local-uploads
LOCAL_STORAGE_BASE_URL=http://localhost:8080
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
LOGOS_XHKG_BASE_URL=
LOGOS_NASDAQ_BASE_URL=
LOGOS_NYSE_BASE_URL=

# Auth
JWT_SIGNING_SECRET=
EMAIL_OTP_MODE=
GOOGLE_ALLOWED_CLIENT_IDS=REPLACE_WITH_IOS_CLIENT_ID,REPLACE_WITH_ANDROID_CLIENT_ID,REPLACE_WITH_ANDROID_DEBUG_CLIENT_ID
APPLE_IOS_BUNDLE_ID=cc.moneycoach.app.ios
BILLING_DEV_MODE=
API_CORS_ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081,https://demo.moneycoach.cc
ENABLE_DANGEROUS_RESET_ROUTES=false
RESET_APP_SECRET=

# External APIs
GEMINI_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
CMC_PRO_API_KEY=
COINGECKO_PRO_API_KEY=
MARKETSTACK_ACCESS_KEY=
OPEN_EXCHANGE_APP_ID=
BINANCE_API_BASE_URL=https://api.binance.com
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com

# Stripe billing (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_WEEKLY=
STRIPE_PRICE_ID_YEARLY=

# Apple IAP (optional)
APPSTORE_SHARED_SECRET=
APPLE_IAP_PRODUCT_ID_WEEKLY=
APPLE_IAP_PRODUCT_ID_YEARLY=

# Push notifications (optional; required for delivery)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY=
APNS_BUNDLE_ID=cc.moneycoach.app.ios
FCM_SERVER_KEY=

# Google Play billing (optional)
GOOGLE_PLAY_PACKAGE_NAME=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_PLAY_PRODUCT_WEEKLY=
GOOGLE_PLAY_PRODUCT_ANNUAL=
GOOGLE_PUBSUB_AUDIENCE=

# Optional: S3 credentials for local dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Optional: override Postgres defaults
POSTGRES_USER=quanta
POSTGRES_PASSWORD=quanta
POSTGRES_DB=quanta
