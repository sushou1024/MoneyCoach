# Backend
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
EXPO_PUBLIC_API_BASE_URL_ANDROID=http://10.0.2.2:8080
EXPO_PUBLIC_PWA_URL=https://demo.moneycoach.cc
EXPO_PUBLIC_TERMS_URL=https://moneycoach.cc/terms
EXPO_PUBLIC_PRIVACY_URL=https://moneycoach.cc/privacy

######## Auth ########

# Google Sign-In
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=1234567890-def.apps.googleusercontent.com
# Required for web/PWA and Android native Google Sign-In
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=1234567890-web.apps.googleusercontent.com
# Optional: Expo Go proxy client ID (only needed when testing in Expo Go)
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=1234567890-mno.apps.googleusercontent.com

######## Payments ########

# Stripe (client-side)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Apple IAP (iOS) - App Store Connect product IDs
EXPO_PUBLIC_APPLE_IAP_PRODUCT_ID_WEEKLY=com.yourapp.pro.weekly
EXPO_PUBLIC_APPLE_IAP_PRODUCT_ID_YEARLY=com.yourapp.pro.yearly
